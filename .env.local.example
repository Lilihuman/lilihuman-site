# ─── Stripe ───────────────────────────────────────────────────────────────────
# Your Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Your Stripe webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Your Stripe publishable key (starts with pk_live_ or pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Optional: Individual Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STRONG_MAMA=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_POSTPARTUM=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_20MIN=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PLANNER=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_COMMAND_CENTRE=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_WALL_ART=price_xxxxxxxxxxxxxxxxxx
STRIPE_PRICE_TOTE=price_xxxxxxxxxxxxxxxxxx

# ─── Site ─────────────────────────────────────────────────────────────────────
# Your production URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://lilihuman.com

# ─── Google Calendar ──────────────────────────────────────────────────────────
# Embed URL from Google Calendar > Settings > Integrate calendar
NEXT_PUBLIC_GOOGLE_CALENDAR_EMBED_URL=https://calendar.google.com/calendar/embed?src=your_calendar_id%40group.calendar.google.com&ctz=Australia%2FSydney

# ─── Email (optional — choose one provider) ───────────────────────────────────
# Resend (recommended): https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# OR SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ─── Analytics (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=lilihuman.com
